# GlobalPulse — Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to git — it contains API keys

# ── Database ──────────────────────────────────────────────────────────────
# Local development (SQLite, no setup needed)
GLOBALPULSE_DB_URL=sqlite:///globalpulse_dev.db

# Production (Supabase PostgreSQL)
# Get from: supabase.com → Your Project → Settings → Database → Connection String → Python
# GLOBALPULSE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.XXXX.supabase.co:5432/postgres

# Supabase (for migrate_to_supabase.py)
# SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.XXXX.supabase.co:5432/postgres

# ── App Mode ──────────────────────────────────────────────────────────────
# Options: research (Optuna + experimental) | production (champion model only)
GLOBALPULSE_MODE=research

# ── Cricket Data — CricAPI ────────────────────────────────────────────────
# Get free key at: https://cricapi.com
# Covers: current matches, live scores, match results
CRICAPI_KEY=your_cricapi_key_here

# ── Weather — OpenWeatherMap ──────────────────────────────────────────────
# Get free key at: https://openweathermap.org/api
# Free tier: 1,000 calls/day
OPENWEATHER_KEY=your_openweather_key_here

# ── Docker PostgreSQL (only if using docker-compose) ──────────────────────
# DB_USER=globalpulse_user
# DB_PASSWORD=change_this_in_production
# DB_NAME=globalpulse_db
